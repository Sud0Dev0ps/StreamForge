# StreamForge environment configuration
# Copy this to .env and fill in actual values

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Timezone
TZ=Your/Timezone

# Shared paths
DATA_PATH=/path/to/shared/data

# Container configurations

# Homepage
HOMEPAGE_ALLOWED_HOSTS=192.168.x.x:3001
HOMEPAGE_PORT=3001
HOMEPAGE_CONFIG_PATH=/path/to/homepage/config

# Navidrome
NAVIDROME_PORT=4533
NAVIDROME_CONFIG_PATH=/path/to/navidrome/config
NAVIDROME_MUSIC_PATH=/path/to/music

# NZBget
NZBGET_CONFIG_PATH=/path/to/nzbget/config
NZBGET_PORT=6789

# Seerr
SEERR_CONFIG_PATH=/path/to/seerr/config
SEERR_PORT=5055

# Prowlarr
PROWLARR_CONFIG_PATH=/path/to/prowlarr/config
PROWLARR_PORT=9696

# Radarr
RADARR_CONFIG_PATH=/path/to/radarr/config
RADARR_PORT=7878

# Sonarr
SONARR_CONFIG_PATH=/path/to/sonarr/config
SONARR_PORT=8989