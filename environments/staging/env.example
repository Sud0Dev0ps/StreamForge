# StreamForge environment configuration
# Copy this to .env and fill in actual values

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Timezone
TZ=Your/Timezone

# Storage paths (adjust for each environment)
config_storage=/path/to/sonarr/config
data_storage=/path/to/shared/data

# Port mapping
sonarr_port=8989