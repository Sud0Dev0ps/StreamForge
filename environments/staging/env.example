# StreamForge environment configuration
# Copy this to .env and fill in actual values

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Timezone
TZ=Your/Timezone

# Shared paths
DATA_PATH=/path/to/shared/data

## Container configurations

# Gluetun (VPN)
GLUETUN_CONFIG_PATH=/path/to/gluetun/config
PROTONVPN_ENDPOINT_IP=your.vpn.endpoint.ip
PROTONVPN_ENDPOINT_PORT=51820
PROTONVPN_PUBLIC_KEY=your_public_key_here
PROTONVPN_PRIVATE_KEY=your_private_key_here
PROTONVPN_ADDRESS=10.2.0.2/32

# NZBget
NZBGET_CONFIG_PATH=/path/to/nzbget/config
NZBGET_DOWNLOADS=/path/to/shared/data/downloads/usenet
NZBGET_PORT=6789

# Prowlarr
PROWLARR_CONFIG_PATH=/path/to/prowlarr/config
PROWLARR_PORT=9696

# Radarr
RADARR_CONFIG_PATH=/path/to/radarr/config
RADARR_PORT=7878

# Sonarr
SONARR_CONFIG_PATH=/path/to/sonarr/config
SONARR_PORT=8989

# qBittorrent
QBITTORRENT_CONFIG_PATH=/path/to/qbittorrent/config
QBITTORRENT_DOWNLOADS=/path/to/downloads/torrents
QBITTORRENT_PORT=8080
QBITTORRENT_CONNECTION_PORT=6881